// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Test {
  id        String   @id @default(uuid())
  name      String
  title     String
  createdAt DateTime @default(now())
} 

model Test2 {
  id        String   @id @default(uuid())
  name2      String
  title2     String
  createdAt DateTime @default(now())
}
